# Copy to .env and adjust. Never commit the real .env.

# SQLite for local dev. Swap for a Postgres URL later with no code changes,
# e.g. DATABASE_URL=postgresql+psycopg://user:pass@host:5432/peerrank
DATABASE_URL=sqlite:///./peerrank.db

# Signs the session token. MUST be a long random string in production
# (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`).
SECRET_KEY=dev-secret-change-me

# Allowed browser origins (comma-separated). "*" is fine for local dev;
# set to your real frontend origin in production, e.g.
# CORS_ORIGINS=https://peerrank.arcitech.ai
CORS_ORIGINS=*

# Session token lifetime (seconds). Default 8h.
TOKEN_TTL_SECONDS=28800

# --- Temporary dev login (replaced by Google OAuth later) ---
# admin / 123  -> admin role
# user  / 123  -> voter, signed in as DEV_VOTER_EMAIL
# any-email / 123 -> voter, signed in as that email
ADMIN_USERNAME=admin
VOTER_USERNAME=user
DEV_PASSWORD=123
ADMIN_EMAIL=admin@peerrank.local
DEV_VOTER_EMAIL=teja@aufgang.com


# Rate limits (per client IP, fixed window in seconds).
LOGIN_RATE_MAX=10
LOGIN_RATE_WINDOW=60
SUBMIT_RATE_MAX=5
SUBMIT_RATE_WINDOW=60

# Auto-close sweep cadence (seconds).
SWEEP_INTERVAL_SECONDS=60

# --- Sign-up + email OTP verification ---
APP_NAME=Peer Rank
PASSWORD_MIN_LENGTH=8
OTP_LENGTH=6
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_RATE_MAX=5
OTP_RATE_WINDOW=300

# DEV master OTP: this code verifies ANY email without the real emailed one, so
# sign-up works before SMTP is set up. SECURITY: MUST be blank in production.
MASTER_OTP=112233

# Google Sign-In: your OAuth 2.0 *Web* client ID (…apps.googleusercontent.com).
# Empty -> the "Sign in with Google" button is hidden. Add your app origin(s)
# (e.g. http://localhost:8000 and your Render URL) as Authorized JavaScript
# origins in the Google Cloud Console for this client.
GOOGLE_CLIENT_ID=

# SMTP for sending the OTP email (Gmail). Leave SMTP_HOST empty in dev — the code
# is then logged to the server console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Peer Rank <no-reply@peerrank.local>
SMTP_USE_TLS=true
